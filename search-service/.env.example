REDIS_PASSWORD=your_redis_password_here

# Service URLs (for simulated event ingestion)
TASK_SERVICE_URL=http://task-service:8002
COMMENT_SERVICE_URL=http://comment-service:8003

# Server
HOST=0.0.0.0
PORT=8004