# Search Service Configuration

# Application
APP_NAME=search-service
APP_VERSION=1.0.0

# Elasticsearch
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
