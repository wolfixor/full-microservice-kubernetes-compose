# Task Service Environment Variables
# Copy this file to .env and fill in the values

# Application
APP_NAME=task-service
APP_VERSION=1.0.0

# Database
POSTGRES_HOST=task-service-db  # For Docker Compose
# POSTGRES_HOST=task-service-db.task-api.svc.cluster.local  # For Kubernetes
POSTGRES_PORT=5432
POSTGRES_DB=task_db
POSTGRES_USER=postgres  # Should be set via environment variable or secret
POSTGRES_PASSWORD=postgres  # Should be set via environment variable or secret

# Server
HOST=0.0.0.0
PORT=8002

# Redis (same for both Docker Compose and Kubernetes)
REDIS_HOST=redis  # Docker Compose container name
# REDIS_HOST=redis-service  # Kubernetes service name
REDIS_PORT=6379
REDIS_DB=1  # Task service uses database 1
REDIS_PASSWORD=  # Can be empty or set
REDIS_KEY_PREFIX=task
CACHE_EXPIRE_SECONDS=300