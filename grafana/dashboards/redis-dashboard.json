{
  "title": "Redis Dashboard",
  "version": 1,
  "uid": "redis-dashboard",
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used"
        },
        {
          "expr": "redis_memory_max_bytes",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Memory Usage (%)",
      "type": "gauge",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      }
    },
    {
      "title": "Evicted Keys",
      "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(redis_evicted_keys_total[5m])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100",
          "legendFormat": "hit ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Command Rate",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(redis_commands_total[5m])",
          "legendFormat": "commands"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Connected Clients",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "clients"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Keyspace Hits vs Misses",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[5m])",
          "legendFormat": "hits"
        },
        {
          "expr": "rate(redis_keyspace_misses_total[5m])",
          "legendFormat": "misses"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "redis_uptime_in_seconds"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"}
        }
      }
    }
  ]
}
