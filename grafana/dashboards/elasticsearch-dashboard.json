{
  "title": "Elasticsearch Dashboard",
  "version": 1,
  "uid": "elasticsearch-dashboard",
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "title": "Cluster Health",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 6},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "elasticsearch_cluster_health_status{color=\"green\"} or elasticsearch_cluster_health_status{color=\"yellow\"} * 2 or elasticsearch_cluster_health_status{color=\"red\"} * 3"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1.5},
              {"color": "red", "value": 2.5}
            ]
          }
        }
      }
    },
    {
      "title": "Active Shards",
      "type": "timeseries",
      "gridPos": {"x": 4, "y": 0, "w": 10, "h": 6},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "elasticsearch_cluster_health_active_shards",
          "legendFormat": "active"
        },
        {
          "expr": "elasticsearch_cluster_health_unassigned_shards",
          "legendFormat": "unassigned"
        },
        {
          "expr": "elasticsearch_cluster_health_relocating_shards",
          "legendFormat": "relocating"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Nodes",
      "type": "stat",
      "gridPos": {"x": 14, "y": 0, "w": 4, "h": 6},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "elasticsearch_cluster_health_number_of_nodes",
          "legendFormat": "nodes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Data Nodes",
      "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 6},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "elasticsearch_cluster_health_number_of_data_nodes",
          "legendFormat": "data nodes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Query Rate",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(elasticsearch_indices_search_query_total[5m]))",
          "legendFormat": "queries"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "qps",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Index Rate",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(elasticsearch_indices_indexing_index_total[5m]))",
          "legendFormat": "indexed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ips",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Index Size",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(elasticsearch_indices_store_size_bytes)",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Document Count",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(elasticsearch_indices_docs_total)",
          "legendFormat": "documents"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Search Latency",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 22, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(elasticsearch_indices_search_query_time_seconds_total[5m]) / rate(elasticsearch_indices_search_query_total[5m])",
          "legendFormat": "avg latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "Indexing Latency",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 22, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(elasticsearch_indices_indexing_index_time_seconds_total[5m]) / rate(elasticsearch_indices_indexing_index_total[5m])",
          "legendFormat": "avg latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"}
        }
      }
    }
  ]
}
